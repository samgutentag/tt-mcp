# Copy this file to .env and fill in values for your target.
# The server reads these at startup; restart the server after changes.

# Base URL of the inference endpoint.
#   Ollama (local dev):   http://localhost:11434
#   Tenstorrent on Koyeb: https://<your-service>.koyeb.app
#   Any OpenAI-compatible vLLM host: http://<host>:8000
TT_ENDPOINT=http://localhost:11434

# Default model name. For Ollama this is the tag (e.g. llama3.2:3b).
# For vLLM this is whatever the server advertises on /v1/models.
TT_MODEL=llama3.2:3b

# Bearer token for authenticated endpoints (Koyeb, hosted vLLM).
# Leave blank for local Ollama, it does not authenticate.
TT_API_KEY=

# Optional human-readable label for the backing hardware, surfaced by the
# `hardware_info` tool. vLLM does not expose hardware details through its
# OpenAI-compatible routes, so this is the operator's declaration.
# Examples: "Tenstorrent Wormhole n300", "Tenstorrent Blackhole"
TT_HARDWARE=
